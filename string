#include<stdio.h>
#include<string.h>
int main(){
    char str[100];
    scanf("%s", str);
    int len=strlen(str);
    int ispalindrom=1;
    for(int i=0; i<len/2; i++){
        if(str[i]!=str[len-i-1]);
        ispalindrom=0;
        break;
    }
    if(ispalindrom){
        printf("YES");
    }
    else
    printf("NO");
}
 
