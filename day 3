// fibonacci series
#include<stdio.h>
int main(){
    int i, term1=0, term2=1, n, fib;
    printf("Enter the position in fibonacci series(n):\n");
    scanf("%d", &n);
    if(n<=0){
        printf("Enter the number greater then 0\n");
        return 0;
    }
    else if(n==1){
        fib=0;
    }
    else if(n==2){
        fib=1;
    }
    else{
        for(i=2; i<n; i++){
            fib=term1+term2;
            term1=term2;
            term2=fib;
        }
    }
    printf("The nth number in fibonacci series is: %d\n", fib);
    return 0;
    
}
