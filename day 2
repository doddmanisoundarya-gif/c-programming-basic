
// Swapping values

#include<stdio.h>
int main(){
    int x, y, temp;
    printf("Enter the value of X: ");
    scanf("%d", &x);
    printf("Enter the value of Y: ");
    scanf("%d", &y);
    printf("Before swaping the value of x=%d, y=%d\n", x, y);
    temp=x;
    x=y;
    y=temp;
    printf("After swaping the value of x=%d, y=%d", x, y);
    return 0;
}

